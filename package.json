{
  "name": "ai-medical-consultation-platform",
  "version": "1.0.0",
  "description": "AI-powered medical consultation platform with doctor oversight",
  "main": "index.js",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node server.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "cdk": "cdk",
    "cdk:deploy": "cdk deploy",
    "cdk:synth": "cdk synth",
    "cdk:destroy": "cdk destroy",
    "local": "docker-compose up",
    "local:init": "bash scripts/init-localstack.sh",
    "validate": "ts-node src/utils/validate-infrastructure.ts"
  },
  "keywords": [
    "medical",
    "ai",
    "aws",
    "healthcare"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/aws-lambda": "^8.10.130",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.11",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.10.6",
    "@types/nodemailer": "^7.0.11",
    "aws-cdk": "^2.117.0",
    "aws-cdk-lib": "^2.117.0",
    "constructs": "^10.3.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.490.0",
    "@aws-sdk/client-dynamodb": "^3.490.0",
    "@aws-sdk/client-s3": "^3.490.0",
    "@aws-sdk/lib-dynamodb": "^3.490.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.2",
    "source-map-support": "^0.5.21"
  }
