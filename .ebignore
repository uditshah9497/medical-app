# Elastic Beanstalk ignore file
# Files and directories to exclude from deployment

# Development files
.git/
.gitignore
.vscode/
.idea/

# Documentation
*.md
!README.md

# Environment files (will be set in EB console)
.env
.env.local
.env.*.local

# Dependencies (will be installed on server)
node_modules/

# Build files
dist/
build/
*.log

# Test files
tests/
*.test.ts
*.test.js
coverage/

# CDK files (not needed for runtime)
cdk.out/
infrastructure/
cdk.json

# LocalStack
docker-compose.yml
localstack-data/
scripts/init-localstack.sh

# Temporary files
tmp/
temp/
*.tmp
