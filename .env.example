# Email Configuration (for real email sending)
# To enable real emails, uncomment and fill in your Gmail credentials
# See SETUP_REAL_EMAILS.md for detailed instructions

# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=your-16-char-app-password

# How to get Gmail App Password:
# 1. Go to https://myaccount.google.com/apppasswords
# 2. Enable 2-Step Verification if not already enabled
# 3. Generate an App Password for "Mail"
# 4. Copy the 16-character password (remove spaces)
# 5. Paste it above as EMAIL_PASS

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=your-account-id

# LocalStack Configuration (for local development)
LOCALSTACK_ENDPOINT=http://localhost:4566
USE_LOCALSTACK=true

# DynamoDB Table Names
PATIENTS_TABLE_NAME=medical-consultation-patients
CONSULTATIONS_TABLE_NAME=medical-consultation-consultations
SYMPTOM_LOGS_TABLE_NAME=medical-consultation-symptom-logs
DOCUMENT_METADATA_TABLE_NAME=medical-consultation-document-metadata

# S3 Bucket Names
DOCUMENT_BUCKET_NAME=medical-consultation-documents

# Cognito Configuration
USER_POOL_ID=your-user-pool-id
USER_POOL_CLIENT_ID=your-client-id

# KMS Configuration
ENCRYPTION_KEY_ID=your-kms-key-id

# Bedrock Configuration
BEDROCK_MODEL_ID=anthropic.claude-v2
BEDROCK_REGION=us-east-1

# Application Configuration
LOG_LEVEL=info
NODE_ENV=development
