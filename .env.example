# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=your-account-id

# LocalStack Configuration (for local development)
LOCALSTACK_ENDPOINT=http://localhost:4566
USE_LOCALSTACK=true

# DynamoDB Table Names
PATIENTS_TABLE_NAME=medical-consultation-patients
CONSULTATIONS_TABLE_NAME=medical-consultation-consultations
SYMPTOM_LOGS_TABLE_NAME=medical-consultation-symptom-logs
DOCUMENT_METADATA_TABLE_NAME=medical-consultation-document-metadata

# S3 Bucket Names
DOCUMENT_BUCKET_NAME=medical-consultation-documents

# Cognito Configuration
USER_POOL_ID=your-user-pool-id
USER_POOL_CLIENT_ID=your-client-id

# KMS Configuration
ENCRYPTION_KEY_ID=your-kms-key-id

# Bedrock Configuration
BEDROCK_MODEL_ID=anthropic.claude-v2
BEDROCK_REGION=us-east-1

# Application Configuration
LOG_LEVEL=info
NODE_ENV=development
